# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://seven_suite:seven_suite_dev@localhost:5432/seven_suite

# ──────────────────────────────────────────────
# Auth.js
# ──────────────────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32

# ──────────────────────────────────────────────
# Microsoft Entra ID (Azure AD) — opcional
# ──────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ──────────────────────────────────────────────
# Resend (transactional email) — opcional
# ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
