@startuml seqRegistrarVisitante

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam sequenceArrowThickness 1.2
skinparam sequenceArrowColor #444444
skinparam participantBorderThickness 1.5
skinparam backgroundColor #FFFFFF

title Secuencia: registrarVisitante()

actor "Empleado\n(navegador)" as U
participant "RSC Page\n/parking/visitantes" as Page
participant "VisitorForm\n(Client Component)" as CC
participant "createVisitorReservation()\nServer Action" as SA
participant "getCurrentUser()\nauth/helpers" as Auth
participant "getResourceConfig()\nconfig.ts" as Cfg
participant "Drizzle ORM\n(db)" as DB
participant "sendVisitorEmail()\nlib/email" as Email
participant "Resend API" as Resend
database "PostgreSQL" as PG

U -> Page : GET /parking/visitantes
Page -> DB : getUpcomingVisitorReservations(userId, entityId)
DB -> PG : SELECT visitor_reservations
PG --> DB : VisitorReservationWithDetails[]
Page --> U : lista de visitas próximas + botón "Nueva visita"

U -> CC : pulsa "Nueva visita"
CC -> SA : getAvailableVisitorSpotsAction(date)
SA -> DB : SELECT spots WHERE type = 'visitor' AND NOT reserved
DB -> PG : query
PG --> DB : spots disponibles
SA --> CC : [{ id, label }]
CC --> U : muestra formulario con plazas disponibles

U -> CC : rellena datos del visitante (nombre, empresa, email, fecha, plaza)
U -> CC : confirma

CC -> SA : createVisitorReservation({ spot_id, date, visitor_name, visitor_company, visitor_email })
SA -> Auth : getCurrentUser()
Auth --> SA : AuthUser

SA -> Cfg : getResourceConfig("parking", "visitor_booking_enabled", entityId)
Cfg --> SA : true

SA -> DB : SELECT spots WHERE id = spot_id
DB -> PG : query
PG --> DB : { label, type: 'visitor', resourceType: 'parking' }

SA -> DB : INSERT INTO visitor_reservations (spotId, reservedBy, date, visitorName, ...)
DB -> PG : INSERT

alt unique constraint violation (plaza ya reservada ese día)
  PG --> DB : UniqueViolationError
  SA --> CC : ActionError("Esta plaza ya tiene reserva de visitante para este día")
else inserción exitosa
  PG --> DB : { id }
  DB --> SA : reservationId

  SA -> Email : sendVisitorReservationEmail(visitorEmail, visitorName, date, spotLabel, ...)
  Email -> Resend : POST /emails
  Resend --> Email : { id }
  Email --> SA : enviado

  SA -> DB : UPDATE visitor_reservations SET notification_sent = true WHERE id = reservationId
  DB -> PG : UPDATE
  SA -> SA : revalidatePath("/parking/visitantes")
  SA --> CC : ActionSuccess({ id: reservationId })
end

CC --> U : confirmación con datos de la visita / mensaje de error

note right of Resend
  El visitante recibe email con
  fecha, plaza y .ics adjunto.
  No tiene acceso al portal.
end note

@enduml
