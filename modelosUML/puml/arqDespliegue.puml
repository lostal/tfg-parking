@startuml arqDespliegue

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam nodeBorderThickness 1.5
skinparam arrowThickness 1.2
skinparam arrowColor #444444
skinparam backgroundColor #FFFFFF

skinparam node {
  BackgroundColor #dce8f5
  BorderColor     #2d6a9f
}

skinparam database {
  BackgroundColor #d5ecd4
  BorderColor     #2e7d32
}

skinparam cloud {
  BackgroundColor #efefef
  BorderColor     #888888
}

title Diagrama de despliegue

node "Navegador del usuario" as Browser {
  artifact "Next.js hydration\n(Client Components)" as Client
}

node "Servidor VPS (Ubuntu)" as VPS {
  node "Docker network" as Docker {
    node "Contenedor Next.js\n(Node.js 20, puerto 3000)" as NextJS {
      artifact "App Router RSC" as RSC
      artifact "Server Actions" as SA
      artifact "API routes\n(/api/auth, /api/...)" as API
    }
    database "Contenedor PostgreSQL 16\n(puerto 5432)" as PG {
      artifact "schema.ts → tablas" as Schema
    }
  }
  artifact "GitHub Actions CI/CD\n(.github/workflows/)" as CICD
}

cloud "Microsoft 365\n(cloud externa)" as M365 {
  node "Microsoft Entra ID\n(OAuth 2.0/OIDC)" as EntraID
  node "Microsoft Graph API\n(Calendar, Teams)" as Graph
}

cloud "Resend\n(cloud externa)" as ResendCloud {
  node "Email API" as Resend
}

Browser -down-> NextJS : HTTPS (puerto 443)\nnginx / reverse proxy
NextJS  -down-> PG     : TCP 5432\nDrizzle ORM
NextJS  -right-> EntraID : OAuth 2.0/OIDC\nsesión JWT
NextJS  -right-> Graph   : Bearer token\nOOO · Teams · Outlook
NextJS  -right-> Resend  : API key\nemail visitantes
CICD    -up-> NextJS     : docker pull / restart

note right of Docker
  Ambos contenedores comparten
  la misma red Docker interna.
  PostgreSQL no está expuesto
  al exterior.
end note

@enduml
