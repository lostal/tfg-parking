@startuml modeloFisico

hide circle
hide empty members

skinparam defaultFontName Arial
skinparam defaultFontSize 10
skinparam classBorderThickness 1.5
skinparam arrowThickness 1.2
skinparam arrowColor #444444
skinparam backgroundColor #FFFFFF

skinparam class {
  BackgroundColor #d5ecd4
  BorderColor     #2e7d32
}

title Modelo fĂ­sico de datos (subset central)

class "**entities**" as E {
  id: UUID PK
  name: text UNIQUE
  short_code: text UNIQUE
  is_active: boolean
  autonomous_community: text
  created_at: timestamptz
}

class "**profiles**" as P {
  id: UUID PK FKâ†’users.id
  email: text
  full_name: text
  role: user_role
  entity_id: UUID FKâ†’entities.id
  manager_id: UUID FKâ†’profiles.id
  dni: text UNIQUE
  job_title: text
  created_at: timestamptz
}

class "**spots**" as S {
  id: UUID PK
  label: text UNIQUE
  type: spot_type
  resource_type: resource_type
  assigned_to: UUID FKâ†’profiles.id
  entity_id: UUID FKâ†’entities.id
  is_active: boolean
  position_x: real
  position_y: real
}

class "**reservations**" as R {
  id: UUID PK
  spot_id: UUID FKâ†’spots.id
  user_id: UUID FKâ†’profiles.id
  date: date
  status: reservation_status
  start_time: time
  end_time: time
  notes: text
  created_at: timestamptz
  --
  UQ: (spot_id, date)\n  WHERE confirmed AND start_time IS NULL
  UQ: (user_id, date)\n  WHERE confirmed AND start_time IS NULL
}

class "**cessions**" as C {
  id: UUID PK
  spot_id: UUID FKâ†’spots.id
  user_id: UUID FKâ†’profiles.id
  date: date
  status: cession_status
  created_at: timestamptz
  --
  UQ: (spot_id, date)\n  WHERE status != 'cancelled'
}

class "**visitor_reservations**" as VR {
  id: UUID PK
  spot_id: UUID FKâ†’spots.id
  reserved_by: UUID FKâ†’profiles.id
  date: date
  visitor_name: text
  visitor_company: text
  visitor_email: text
  status: reservation_status
  notification_sent: boolean
  --
  UQ: (spot_id, date) WHERE confirmed
}

class "**leave_requests**" as LR {
  id: UUID PK
  employee_id: UUID FKâ†’profiles.id
  leave_type: leave_type
  start_date: date
  end_date: date
  status: leave_status
  manager_id: UUID FKâ†’profiles.id
  hr_id: UUID FKâ†’profiles.id
  working_days: smallint
}

class "**announcements**" as AN {
  id: UUID PK
  title: text
  body: text
  entity_id: UUID FKâ†’entities.id
  published_at: timestamptz
  expires_at: timestamptz
  created_by: UUID FKâ†’profiles.id
}

class "**system_config**" as SC {
  key: text PK
  value: jsonb
  updated_at: timestamptz
  updated_by: UUID FKâ†’profiles.id
}

E "1" -- "N" P   : entidad >
E "1" -- "N" S   : dispone de >
E "0..1" -- "N" AN : publica >

P "1" -- "N" R   : realiza >
P "1" -- "N" C   : cede >
P "1" -- "N" VR  : gestiona >
P "1" -- "N" LR  : solicita >
P "0..1" -- "N" S : < asignada a

S "1" -- "N" R   : es objeto de >
S "1" -- "N" C   : es objeto de >
S "1" -- "N" VR  : es objeto de >

note right of R
  El trigger sync_cession_on_reservation
  actualiza cessions.status = 'reserved'
  cuando se inserta una reserva sobre
  una cesiĂłn activa, y viceversa.
end note

note right of SC
  Claves: "parking.max_advance_days",
  "office.time_slots_enabled", etc.
  Cacheado con unstable_cache
  (TTL 5 min, tag "system-config").
end note

@enduml
